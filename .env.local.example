# ─────────────────────────────────────────────────────────────
#  Contact Form — Gmail SMTP Setup
#  Copy this file to .env.local and fill in your credentials.
# ─────────────────────────────────────────────────────────────

# Your Gmail address (the one that receives inquiries)
GMAIL_USER=psudai@gmail.com

# Gmail App Password (NOT your regular Gmail password)
# How to generate one:
#   1. Go to myaccount.google.com → Security
#   2. Enable 2-Step Verification (if not already on)
#   3. Search "App passwords" in the Security search bar
#   4. Create a new App Password → select Mail → Any device
#   5. Copy the 16-character code and paste it below (no spaces)
GMAIL_APP_PASSWORD=your-16-char-app-password-here

# ─────────────────────────────────────────────────────────────
#  After filling in:
#   npm run dev   →  test the contact form locally
#   On Vercel:    →  add these as Environment Variables in
#                    your project settings
# ─────────────────────────────────────────────────────────────
